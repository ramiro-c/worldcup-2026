{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "worldcup-2026",
  "compatibility_date": "2026-06-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "ANALYTICS_KV",
      "id": "{env:ANALYTICS_KV_ID}"
    }
  ]
}
