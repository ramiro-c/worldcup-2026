meta {
  name: Get Matches
  type: http
  seq: 5
}

get {
  url: http://localhost:8000/tournament/matches
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns data array", function() {
    expect(res.body.data).to.be.an("array");
  });
  test("has 104 matches", function() {
    expect(res.body.data.length).to.equal(104);
  });
  test("each match has num, date, phase, slug", function() {
    res.body.data.forEach(function(m) {
      expect(m.num).to.be.a("number");
      expect(m.date).to.be.a("string");
      expect(m.phase).to.be.a("string");
      expect(m.slug).to.be.a("string");
    });
  });
  test("first match is Mexico vs South Africa", function() {
    var first = res.body.data[0];
    expect(first.home).to.equal("MEX");
    expect(first.away).to.equal("RSA");
  });
  test("final match is on 2026-07-19", function() {
    var final = res.body.data.find(function(m) { return m.phase === "final"; });
    expect(final).to.not.be.undefined;
    expect(final.date).to.equal("2026-07-19");
  });
  test("each match has status, home_score, away_score fields", function() {
    res.body.data.forEach(function(m) {
      expect(m).to.have.property("status");
      expect(m).to.have.property("home_score");
      expect(m).to.have.property("away_score");
    });
  });
  test("status is lowercase string", function() {
    res.body.data.forEach(function(m) {
      expect(m.status).to.be.a("string");
      expect(m.status).to.match(/^(scheduled|live|finished|[a-z]+)$/);
    });
  });
  test("home_score and away_score are number or null", function() {
    res.body.data.forEach(function(m) {
      expect(m.home_score === null || typeof m.home_score === "number").to.be.true;
      expect(m.away_score === null || typeof m.away_score === "number").to.be.true;
    });
  });
}
