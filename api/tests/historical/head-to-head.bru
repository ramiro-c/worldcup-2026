meta {
  name: Head to Head
  type: http
  seq: 12
}

get {
  url: http://localhost:8000/historical/head-to-head?team1=Argentina&team2=France
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns data array", function() {
    expect(res.body.data).to.be.an("array");
  });
  test("includes 2022 final", function() {
    var matches = res.body.data;
    var final2022 = matches.filter(function(m) {
      return m.stage === "final" && m.team1.name === "Argentina";
    });
    expect(final2022.length).to.equal(1);
    expect(final2022[0].penalty_score).to.equal("4-2");
  });
}
